{
  "version": 2,
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/api/auth/x/login",
      "dest": "/api/auth/x/login.js",
      "methods": ["GET", "OPTIONS"]
    },
    {
      "src": "/api/auth/x/callback",
      "dest": "/api/auth/x/callback.js",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/api/auth/x/user",
      "dest": "/api/auth/x/user.js",
      "methods": ["GET", "OPTIONS"]
    },
    {
      "src": "/api/leaderboard",
      "dest": "/api/leaderboard.js",
      "methods": ["GET", "OPTIONS"]
    },
    {
      "src": "/api/webhook/x-activity",
      "dest": "/api/webhook/x-activity.js",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/api/cron/search-x-mentions",
      "dest": "/api/cron/search-x-mentions.js",
      "methods": ["GET", "OPTIONS"]
    },
    {
      "src": "/api/verify-x-post",
      "dest": "/api/verify-x-post.js",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "REDIRECT_URI_LOCAL": "http://localhost:3000/callback.html",
    "REDIRECT_URI_VERCEL": "https://avaxcoco.vercel.app/callback.html",
    "REDIRECT_URI_PROD_WWW": "https://www.avaxcoco.com/callback.html",
    "REDIRECT_URI_PROD": "https://avaxcoco.com/callback.html"
  },
  "crons": [
    {
      "path": "/api/cron/search-x-mentions",
      "schedule": "0 0 * * *"
    }
  ]
}